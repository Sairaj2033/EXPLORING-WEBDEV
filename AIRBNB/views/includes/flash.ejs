<% if (success && success.length ){ %>
    <div class="col-6 offset-3   alert  alert-dismissible fade show alert-success" role="alert">

<%= success %>

 <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
</div>
<%  } %>

<!--  -->
<% if (error && error.length ){ %>
<div class="col-6 offset-3   alert  alert-dismissible fade show alert-danger" role="alert">
     <%= error %>
     <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
</div>
<%  } %>
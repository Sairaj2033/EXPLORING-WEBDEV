<!-- Scroll Animation Script -->
<script>
    document.addEventListener("scroll", () => {
        const bigSearch = document.getElementById("big-search");
        const compactSearch = document.getElementById("compact-search");
        const centerTabs = document.getElementById("center-tabs");

        if (window.scrollY > 50) {
            // Scroll down: Hide Big Search & Tabs, Show Compact Pill
            if (bigSearch) {
                bigSearch.style.opacity = "0";
                bigSearch.style.transform = " translateY(-20px)";
                bigSearch.style.pointerEvents = "none";
                bigSearch.style.height = "0"; // Collapses the space
            }
            if (centerTabs) centerTabs.style.opacity = "0";
            if (compactSearch) {
                compactSearch.style.opacity = "1";
                compactSearch.style.transform = "translateX(-50%) ";
                compactSearch.style.pointerEvents = "auto";
            }
        } else {
            // Scroll up: Reset everything
            if (bigSearch) {
                bigSearch.style.opacity = "1";
                bigSearch.style.transform = "scale(1) translateY(0)";
                bigSearch.style.pointerEvents = "auto";
                bigSearch.style.height = "auto"; 
            }
            if (centerTabs) centerTabs.style.opacity = "1";
            if (compactSearch) {
                compactSearch.style.opacity = "0";
                compactSearch.style.transform = "translateX(-50%) ";
                compactSearch.style.pointerEvents = "none";
            }
        }
    });
</script>
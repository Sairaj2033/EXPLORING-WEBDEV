<div class="row row-cols-lg-6 row-cols-md-3 row-cols-sm-1">
     <% for(let listing of  allListings) { %>
<a  class="card-a" href="/listings/<%= listing._id %>">        
<div class=" card lisitng-card" style="width: 13rem">


  <img src="<%=listing.image.url%>" class="card-img" alt="listing_image" style="height: 13rem;"/>

  <div class="card-img-overlay"></div>


  <div style="font-size:85%;" class="card-body">
    <p class="card-text">
       <b><%=listing.title %></b> <br>
          &#8377; <%= listing.price.toLocaleString("en-IN")%>/night  
    </p>
  </div> 
</div>

</a>
<% } %>
</div>


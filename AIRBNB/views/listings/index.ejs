<% layout("/layouts/boilerplate") %>

<div style="margin-top: 1rem !important; margin-bottom: 1.5rem !important;">
  <% if(!currUser){ %>
  <p style="background-color: rgb(0, 0, 0); height: 50px !important; border-radius: 3rem; " class=" alert alert-success alert-dismissible fade show col-10 offset-1 mt-2 d-flex justify-content-center align-items-center" role="alert"> <a  href="/signup"> <button  style=" border: none; font-size: 17px; margin-left: 1.5rem !important;" class="btn  ms-5" > <b style="color: rgb(255, 255, 255);">Get Started!</b></button></a></p>
 <% } %>  
</div>
  


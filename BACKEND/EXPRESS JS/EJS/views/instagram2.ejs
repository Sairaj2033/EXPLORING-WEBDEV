 <!DOCTYPE html>
 <html lang="en">
 <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=h2, initial-scale=1.0">
    <title>Instagram</title>
    <style> 
       img{
         height: 150px;
         width : 150px;
       }
    </style>
 </head>
 <body>
    <h2> This page belongs to <%= data.name %> </h2>
    <button>Follow</button>
    <button>Message</button>

      <p>Followers : <%= data.followers %></p> &nbsp;&nbsp;&nbsp;&nbsp; <p>Following : <%= data.following %></p>
    <hr/>

   <% for(let post of data.posts) { %>
       <img src="<%= post.image %>" alt="some img">
       <p>likes : <%= post .likes %></p>
      <ul>
<% post.comments.forEach(c => { %>
    <li><%= c.username %>: <%= c.text %></li>
<% }) %>
</ul>
   <% } %>

 </body>
 </html> 
